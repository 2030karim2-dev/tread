# Environment Variables Template
# انسخ هذا الملف إلى .env.local وعدّل القيم

# API Configuration
VITE_API_URL=/api
VITE_API_TIMEOUT=30000

# Authentication (إذا كنت تستخدم مصادقة)
# VITE_AUTH_ENABLED=true
# VITE_AUTH_PROVIDER=supabase  # أو firebase, custom

# Supabase (إذا كنت تستخدم Supabase)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Firebase (إذا كنت تستخدم Firebase)
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id

# Currency API (اختياري)
# VITE_EXCHANGE_RATE_API=https://api.exchangerate-api.com/v4

# Analytics (اختياري)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Features
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=false
