{
  "expo": {
    "name": "China Trade Assistant Pro",
    "slug": "china-trade-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "chinatrade",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chinatrade.assistant"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "package": "com.chinatrade.assistant",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow China Trade Assistant to use your location."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow China Trade Assistant to access your camera."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow China Trade Assistant to access your microphone."
        }
      ],
      "expo-local-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}